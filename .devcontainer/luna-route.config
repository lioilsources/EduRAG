host: "0.0.0.0"
port: 8081
api_dialect: "openai"

providers:
  openai:
    enabled: true
    base_url: "https://llm.ol1n.com"

pii:
  enabled: true
  redact_email: true
  redact_phone: true
  redact_ssn: true
  redact_credit_card: true
  redact_ip: true
  redaction_mode: "tokenize"

logging:
  enabled: true
  level: info
  store_prompts: true
  store_responses: false
