FROM rust:1.94-slim AS builder
WORKDIR /app
COPY . .
RUN cargo build --release --bin lunaroute-server

FROM debian:trixie-slim
RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*
COPY --from=builder /app/target/release/lunaroute-server /usr/local/bin/lunaroute-server
EXPOSE 8081 8082
ENTRYPOINT ["lunaroute-server"]
